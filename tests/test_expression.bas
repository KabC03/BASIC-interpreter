10 REM Expression evaluation
20 LET A = 2
30 LET B = 3
40 LET C = 4
50 PRINT "A="; A; " B="; B; " C="; C
60 LET RESULT = A + B * C
70 PRINT "A + B * C = "; RESULT
80 LET RESULT = (A + B) * C
90 PRINT "(A + B) * C = "; RESULT
100 LET RESULT = A * A + B * B
110 PRINT "A^2 + B^2 = "; RESULT
120 LET RESULT = (A + B + C) / 3
130 PRINT "Average = "; RESULT
140 END

